# DeepSeek API Key
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ZHIPU API Key
ZHIPU_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxx

# Bilibili Cookie (Optional, but recommended for subtitle access)
# Get this from browser cookies: SESSDATA
BILIBILI_SESSDATA=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Supabase / Prisma Database
# 重要：在 Vercel 等 serverless 环境中，必须使用连接池模式
# DATABASE_URL: 用于应用连接，使用 Transaction 模式（端口 6543 + pgbouncer=true + pool_timeout=0）
# DIRECT_URL: 用于 Prisma 迁移，使用 Session 模式（端口 5432，直连数据库）
# 
# Supabase 连接字符串获取方式：
# 1. 打开 Supabase 项目 -> Settings -> Database
# 2. 找到 "Connection string" 部分
# 3. DATABASE_URL 使用 "Transaction" 模式的连接字符串（端口 6543）
# 4. DIRECT_URL 使用 "Session" 模式的连接字符串（端口 5432）
#
# 示例格式：
DATABASE_URL="postgresql://postgres.xxxxxxxxxxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&pool_timeout=0"
DIRECT_URL="postgresql://postgres.xxxxxxxxxxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# YunGouOS Payment
YUNGOUOS_MCH_ID=xxxxxxxxxx
YUNGOUOS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_APP_URL=http://localhost:3000